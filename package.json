{
  "name": "gallery-view",
  "version": "0.1.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Tes npm run\" && exit 1",
    "build:css": "tailwindcss -i ./input.css -o ./static/output.css",
    "watch:css": "tailwindcss -i ./input.css -o ./static/output.css --watch",
    "build:ts": "esbuild src/js/**/*.ts --outdir=static/js --bundle --format=esm --splitting --sourcemap",
    "watch:ts": "esbuild src/js/**/*.ts --outdir=static/js --bundle --format=esm --splitting --sourcemap --watch",
    "dev": "concurrently \"npm run watch:css\" \"npm run watch:ts\"",
    "build": "npm run build:css && npm run build:ts",
    "start": "poetry run python app.py"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myrhm/gallery-view.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/myrhm/gallery-view/issues"
  },
  "homepage": "https://github.com/myrhm/gallery-view#readme",
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "hammerjs": "^2.0.8"
  }
}
